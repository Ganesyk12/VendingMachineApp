@model VendingMachineApp.Models.UserTransaction
@{
    ViewData["Title"] = "Tambah Transaksi";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="vending-card animate__animated animate__fadeInUp">
            <h2 class="page-title mb-4">Manual Transaction</h2>

            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="IdUser" class="form-label text-info small fw-bold">PELANGGAN</label>
                        <select asp-for="IdUser" class="form-select vending-form-control">
                            <option value="">-- Pilih User --</option>
                            @if (ViewData["Users"] is List<VendingMachineApp.Models.UserLogin> users)
                            {
                                foreach (var user in users)
                                {
                                    <option value="@user.IdUser">@user.UserBalance?.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label text-info small fw-bold">PRODUK</label>
                        <select name="idProduct" class="form-select vending-form-control">
                            <option value="">-- Pilih Produk --</option>
                            @if (ViewData["Products"] is List<VendingMachineApp.Models.Product> products)
                            {
                                foreach (var product in products)
                                {
                                    <option value="@product.IdProduct">@product.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalAmount" class="form-label text-info small fw-bold">NOMINAL TOTAL (RP)</label>
                        <input asp-for="TotalAmount" name="amount" id="TotalAmount" class="form-control vending-form-control" type="text" autocomplete="off"/>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="TransactionType" class="form-label text-info small fw-bold">TIPE TRANSAKSI</label>
                        <select asp-for="TransactionType" class="form-select vending-form-control">
                            <option value="Pembelian">Pembelian</option>
                            <option value="Penambahan Saldo">Penambahan Saldo</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <a href="@Url.Action("Index", "Transaction")" class="text-muted text-decoration-none small">
                        <i class="fas fa-arrow-left me-1"></i> Kembali ke Riwayat
                    </a>
                    <button type="submit" class="btn-vending">
                        <i class="fas fa-plus-circle me-2"></i>PROSES TRANSAKSI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#Amount').on('input', function () {
                let val = $(this).val().replace(/[^\d]/g, '');
                if (val !== "") {
                    $(this).val(parseInt(val).toLocaleString('id-ID'));
                }
            });

            $('form').on('submit', function () {
                let amountInput = $('#Amount');
                let rawValue = amountInput.val().replace(/[^\d]/g, '');
                amountInput.val(rawValue);
            });
        });
    </script>
}

