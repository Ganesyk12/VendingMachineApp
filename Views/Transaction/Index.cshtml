@model IEnumerable<VendingMachineApp.Models.UserTransaction>
@{
    ViewData["Title"] = "History Transaksi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Transaction History</h1>
</div>

<div class="vending-table-container">
    <div class="table-responsive">
        <table class="table table-vending">
            <thead>
            <tr>
                <th>Trx Code</th>
                <th>User</th>
                <th>Type</th>
                <th>Total Amount</th>
                <th>Balance After</th>
                <th>Date</th>
                <th class="text-center">Action</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var transaction in Model)
            {
                <tr>
                    <td>
                        <span class="text-info fw-bold">@transaction.TrxCode</span>
                    </td>
                    <td>
                        <span class="fw-bold">@transaction.User?.UserBalance?.Name</span>
                    </td>
                    <td>
                        <span class="badge @(transaction.TransactionType == "Pembelian" ? "bg-info" : "bg-success")">
                            @transaction.TransactionType
                        </span>
                    </td>
                    <td>
                        <span class="@(transaction.TransactionType == "Pembelian" ? "text-danger" : "text-success")">Rp @transaction.TotalAmount.ToString("N0")</span>
                    </td>
                    <td>Rp @transaction.BalanceAfterTransaction?.ToString("N0")</td>
                    <td>
                        <span class="small text-muted">@transaction.Date.ToString("g")</span>
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@transaction.IdTransaction" class="btn btn-sm btn-outline-info">
                            <i class="fas fa-eye me-1"></i>Detail
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
