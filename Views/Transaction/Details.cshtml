@model VendingMachineApp.Models.UserTransaction
@{
   ViewData["Title"] = "Transaction Detail";
}

<div class="d-flex justify-content-between align-items-center mb-4">
   <h1 class="page-title mb-0">Detail Transaksi: <span class="text-info">@Model.TrxCode</span></h1>
</div>

<div class="row">
   <div class="col-md-4 mb-4">
      <!-- Header Info -->
      <div class="vending-card">
         <h5 class="text-info mb-4 border-bottom border-secondary pb-2">Informasi Umum</h5>
         <div class="mb-3">
            <small class="text-muted d-block">Pelanggan</small>
            <div class="fw-bold text-white fs-5">@Model.User?.UserBalance?.Name</div>
         </div>
         <div class="mb-3">
            <small class="text-muted d-block">Tanggal Transaksi</small>
            <div class="fw-bold text-white">@Model.Date.ToString("dd MMMM yyyy, HH:mm:ss")</div>
         </div>
         <div class="mb-3">
            <small class="text-muted d-block">Tipe Transaksi</small>
            <div>
               <span class="badge @(Model.TransactionType == "Pembelian" ? "bg-info" : "bg-success") fs-6 mt-1">
                  @Model.TransactionType
               </span>
            </div>
         </div>
         <div class="mb-3">
            <small class="text-muted d-block">Sisa Saldo Akhir</small>
            <div class="fw-bold text-white">Rp @Model.BalanceAfterTransaction?.ToString("N0")</div>
         </div>
         <div class="mt-4 pt-3 border-top border-secondary">
            <small class="text-muted d-block">Total Keseluruhan</small>
            <div class="fs-2 fw-bold text-info">Rp @Model.TotalAmount.ToString("N0")</div>
         </div>
      </div>
   </div>

   <div class="col-md-8 mb-4">
      <!-- Rincian Produk -->
      <div class="vending-card h-100">
         <h5 class="text-info mb-4 border-bottom border-secondary pb-2">Daftar Item Dibeli</h5>

         @if (Model.TransactionDetails != null && Model.TransactionDetails.Any())
         {
            <div class="table-responsive">
               <table class="table table-vending table-sm">
                  <thead>
                  <tr>
                     <th>Produk</th>
                     <th class="text-end">Harga Satuan</th>
                     <th class="text-center">Jumlah</th>
                     <th class="text-end">SubTotal</th>
                  </tr>
                  </thead>
                  <tbody>
                  @foreach (var item in Model.TransactionDetails)
                  {
                     <tr>
                        <td>
                           <span class="fw-bold text-white">@(item.Product?.Name ?? "Item Tidak Diketahui")</span>
                        </td>
                        <td class="text-end">
                           <span class="text-muted">Rp @item.Price.ToString("N0")</span>
                        </td>
                        <td class="text-center">
                           <span class="badge bg-secondary">x @item.Quantity</span>
                        </td>
                        <td class="text-end">
                           <span class="fw-bold text-info">Rp @item.SubTotal.ToString("N0")</span>
                        </td>
                     </tr>
                  }
                  </tbody>
               </table>
            </div>
         }
         else
         {
            <div class="text-center py-5 text-muted">
               <i class="fas fa-box-open fa-3x mb-3"></i>
               <p>Tidak ada rincian item (Misalnya ini adalah transaksi Topup murni).</p>
            </div>
         }

         <div class="mt-4 pt-3 border-top border-secondary d-flex justify-content-end">
            <button id="btnSendReceipt" class="btn btn-outline-info rounded-pill px-4 me-2" data-id="@Model.IdTransaction">
               <i class="fas fa-envelope me-2"></i>Kirim Bukti Transaksi
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
               <i class="fas fa-arrow-left me-2"></i>Kembali
            </a>
         </div>
      </div>
   </div>
</div>

@section Scripts {
   <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
   <script>
        $(document).ready(function () {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#212529',
                color: '#fff',
                customClass: {
                    popup: 'mt-5'
                },
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            $('#btnSendReceipt').click(function () {
                var btn = $(this);
                var trxId = btn.data('id');
                var originalHtml = btn.html();

                // Loading State
                btn.prop('disabled', true);
                btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Mengirim...');

                $.ajax({
                    url: '@Url.Action("SendReceiptEmail", "Transaction")',
                    type: 'POST',
                    data: { id: trxId },
                    success: function (response) {
                        if (response.success) {
                            Toast.fire({
                                icon: 'success',
                                title: 'Berhasil',
                                text: response.message
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Gagal',
                                text: response.message
                            });
                        }
                    },
                    error: function (xhr) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Terjadi kesalahan sistem saat menghubungi server.'
                        });
                    },
                    complete: function () {
                        // Reset button
                        btn.prop('disabled', false);
                        btn.html(originalHtml);
                    }
                });
            });
        });
    </script>
}
