@model IEnumerable<VendingMachineApp.Models.ViewModels.UserRoleListViewModel>
@{
    int? filterUserId = ViewBag.UserId as int?;
    string title = filterUserId != null ? "Kelola Role" : "Manajemen Role User";
    ViewData["Title"] = title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">@title</h1>
        @if (filterUserId != null)
        {
            <h3 class="text-info mt-2 h5">@ViewBag.UserName</h3>
        }
    </div>
    <div class="d-flex gap-2">
        @if (filterUserId != null)
        {
            <a href="@Url.Action("Index", "UserManagement")" class="btn btn-outline-secondary py-1 px-3 mt-1">
                <i class="fas fa-arrow-left me-1"></i> Kembali ke Daftar Pengguna
            </a>
        }
        <a href="@Url.Action("Create", "UserRole", new { userId = filterUserId })" class="btn-vending py-1 px-3">
            <i class="fas fa-plus me-1"></i>Tambah Role
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="vending-table-container">
    <div class="table-responsive">
        <table class="table table-vending">
            <thead>
            <tr>
                @if (filterUserId == null)
                {
                    <th>User</th>
                }
                <th>Role</th>
                <th>Status</th>
                <th class="text-center">Aksi</th>
            </tr>
            </thead>
            <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        @if (filterUserId == null)
                        {
                            <td>
                                <span class="fw-bold text-white">@item.UserName</span>
                            </td>
                        }
                        <td>
                            <span class="badge bg-info text-dark">@item.RoleName</span>
                        </td>
                        <td>
                            <span class="badge @(item.Status == "A" ? "bg-success" : "bg-secondary")">
                                @(item.Status == "A" ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="@Url.Action("Edit", "UserRole", new { id = item.IdUserRole })" class="btn btn-sm btn-outline-info me-2" title="Edit Role">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.IdUserRole" method="post" class="d-inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus role ini?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus Role">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@(filterUserId == null ? 4 : 3)" class="text-center py-4 text-white-50">Belum ada role yang ditugaskan.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
