@model IEnumerable<VendingMachineApp.Models.ViewModels.UserRoleListViewModel>
@{
    ViewData["Title"] = "Manajemen Role User";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Daftar Role User</h1>
    <a href="@Url.Action("Create", "UserRole")" class="btn-vending py-1 px-3">
        <i class="fas fa-plus me-1"></i>Tambah Role
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="vending-table-container">
    <div class="table-responsive">
        <table class="table table-vending">
            <thead>
            <tr>
                <th>User</th>
                <th>Role</th>
                <th class="text-center">Aksi</th>
            </tr>
            </thead>
            <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="fw-bold text-white">@item.UserName</span>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@item.RoleName</span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="@Url.Action("Edit", "UserRole", new { id = item.IdUserRole })" class="btn btn-sm btn-outline-info me-2" title="Edit Role">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.IdUserRole" method="post" class="d-inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus role ini?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus Role">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center py-4 text-white-50">Belum ada role yang ditugaskan.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
