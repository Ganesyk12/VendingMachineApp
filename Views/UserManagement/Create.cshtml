@model VendingMachineApp.Models.ViewModels.UserCreateViewModel
@{
    ViewData["Title"] = "Tambah Pengguna";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="vending-card animate__animated animate__fadeInUp">
            <h2 class="page-title mb-4">Tambah Pengguna Baru</h2>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label text-info small fw-bold"></label>
                    <input asp-for="Name" class="form-control vending-form-control" placeholder="Masukkan nama lengkap..."/>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-info small fw-bold"></label>
                    <input asp-for="Email" class="form-control vending-form-control" type="email" placeholder="example@email.com"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-info small fw-bold"></label>
                    <input asp-for="Password" class="form-control vending-form-control" type="password" placeholder="Masukkan password..."/>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-info small fw-bold"></label>
                    <input asp-for="ConfirmPassword" class="form-control vending-form-control" type="password" placeholder="Konfirmasi password..."/>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <a href="@Url.Action("Index", "UserManagement")" class="btn btn-secondary text-white py-2 px-4 rounded-pill border-0 hover-vending-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Kembali
                    </a>
                    <button type="submit" class="btn-vending">
                        <i class="fas fa-save me-2"></i>SIMPAN
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
