@model IEnumerable<VendingMachineApp.Models.Product>
@{
    ViewData["Title"] = "Product Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Product List</h1>
    <a href="@Url.Action("Create", "Product")" class="btn-vending py-1 px-3">
        <i class="fas fa-plus me-1"></i>Tambah Produk
    </a>
</div>

<div class="vending-table-container">
    <div class="table-responsive">
        <table class="table table-vending">
            <thead>
            <tr>
                <th>Nama Produk</th>
                <th>Harga</th>
                <th>Jumlah</th>
                <th class="text-center">Aksi</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>
                        <span class="fw-bold">@product.Name</span>
                    </td>
                    <td>
                        <span class="text-info">Rp @product.Price.ToString("N0")</span>
                    </td>
                    <td>@product.Quantity</td>
                    <td class="text-center text-nowrap">
                        <a href="@Url.Action("Edit", "Product", new { id = product.IdProduct })" class="btn btn-sm btn-outline-info me-2">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a href="@Url.Action("Delete", "Product", new { id = product.IdProduct })" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
