@model VendingMachineApp.Models.Product
@{
    ViewData["Title"] = "Edit Produk";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="vending-card animate__animated animate__fadeInUp">
            <h2 class="page-title mb-4">Edit Produk</h2>
            
            <form asp-action="Edit">
                <input type="hidden" asp-for="IdProduct" />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label text-info small fw-bold">NAMA PRODUK</label>
                    <input asp-for="Name" class="form-control vending-form-control" placeholder="Masukkan nama produk..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label text-info small fw-bold">HARGA (RP)</label>
                    <input asp-for="Price" class="form-control vending-form-control" type="number" placeholder="0" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Quantity" class="form-label text-info small fw-bold">JUMLAH STOK</label>
                    <input asp-for="Quantity" class="form-control vending-form-control" type="number" min="0" placeholder="0" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <a href="@Url.Action("Index", "Product")" class="text-muted text-decoration-none small">
                        <i class="fas fa-arrow-left me-1"></i> Kembali ke Daftar
                    </a>
                    <button type="submit" class="btn-vending">
                        <i class="fas fa-check-circle me-2"></i>PERBARUI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
