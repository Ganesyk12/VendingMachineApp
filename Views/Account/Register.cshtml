@model RegisterViewModel
@{
    ViewData["Title"] = "Register - Vending Machine";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="vending-card animate__animated animate__fadeInUp">
            <h2 class="page-title text-center mb-4"><i class="fas fa-user-plus me-2 text-info"></i>REGISTRASI</h2>

            <form id="registerForm" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label text-info small fw-bold">NAMA LENGKAP</label>
                        <input asp-for="Name" class="form-control vending-form-control" placeholder="John Doe"/>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label text-info small fw-bold">EMAIL ADDRESS</label>
                        <input asp-for="Email" id="userEmail" class="form-control vending-form-control" placeholder="john@example.com"/>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label text-info small fw-bold">PASSWORD</label>
                        <input asp-for="Password" class="form-control vending-form-control" type="password" placeholder="••••••••"/>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ConfirmPassword" class="form-label text-info small fw-bold">KONFIRMASI PASSWORD</label>
                        <input asp-for="ConfirmPassword" class="form-control vending-form-control" type="password" placeholder="••••••••"/>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="button" id="btnRequestCode" class="btn-vending w-100 mb-3 mt-3">
                    <i class="fas fa-paper-plane me-2"></i>KIRIM KODE VERIFIKASI
                </button>

                <input type="hidden" asp-for="VerificationCode" id="hiddenVerificationCode" value="000000"/>

                <div class="text-center">
                    <span class="text-muted small">Sudah punya akun? </span>
                    <a asp-action="Login" class="text-info small text-decoration-none fw-bold">Login Disini</a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Verifikasi -->
<div class="modal fade" id="verificationModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-info">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title text-info"><i class="fas fa-shield-alt me-2"></i>Verifikasi Email</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p class="small text-white-50 mb-4">Kode verifikasi 6-digit telah dikirim ke email Anda. Masukkan kode tersebut di bawah ini:</p>

                <div class="mb-4">
                    <input type="text" id="modalCodeInput" class="form-control vending-form-control text-center fs-3 letter-spacing-5 mx-auto" style="max-width: 250px; letter-spacing: 12px; font-weight: bold;" maxlength="6" placeholder="------" autocomplete="off">
                    <span id="codeError" class="text-danger small d-none mt-2">Format kode tidak valid. Harus 6 angka.</span>
                </div>

                <div class="d-flex flex-column justify-content-center align-items-center">
                    <h3 id="countdownTimer" class="text-warning mb-3">01:00</h3>
                    <button type="button" id="btnResendCode" class="btn btn-sm btn-outline-info d-none mb-3">
                        <i class="fas fa-redo-alt me-1"></i>Kirim Ulang Kode
                    </button>
                    <button type="button" id="btnSubmitForm" class="btn-vending w-100 mt-2">
                        <i class="fas fa-check-circle me-2"></i>SELESAIKAN PENDAFTARAN
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        $(document).ready(function () {
            let countdownInterval;
            
            $("#btnRequestCode").click(function () {
                var form = $("#registerForm");
                
                // Trigger jQuery Validate
                if (!form.valid()) {
                    return;
                }
                
                var emailVal = $("#userEmail").val();
                
                $(this).prop('disabled', true);
                $(this).html('<i class="fas fa-circle-notch fa-spin me-2"></i>Mengirim...');

                $.ajax({
                    url: '@Url.Action("SendVerificationCode", "Account")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        Name: $("#Name").val(),
                        Email: emailVal,
                        Password: $("#Password").val(),
                        ConfirmPassword: $("#ConfirmPassword").val(),
                        VerificationCode: '000000' // Stub just to pass model binding
                    }),
                    success: function (res) {
                        $("#btnRequestCode").prop('disabled', false);
                        $("#btnRequestCode").html('<i class="fas fa-paper-plane me-2"></i>KIRIM KODE VERIFIKASI');

                        if (res.success) {
                            $("#verificationModal").modal("show");
                            startCountdown(60);
                        } else {
                            alert("Gagal: " + res.message);
                        }
                    },
                    error: function () {
                        $("#btnRequestCode").prop('disabled', false);
                        $("#btnRequestCode").html('<i class="fas fa-paper-plane me-2"></i>KIRIM KODE VERIFIKASI');
                        alert("Terjadi kesalahan jaringan.");
                    }
                });
            });

            $("#btnResendCode").click(function() {
                $("#btnRequestCode").click(); // Trigger the whole flow again
            });

            $("#btnSubmitForm").click(function() {
                var code = $("#modalCodeInput").val();
                if(code.length !== 6 || isNaN(code)) {
                    $("#codeError").removeClass("d-none");
                    return;
                }
                
                $("#codeError").addClass("d-none");
                
                // Copy the value to the hidden input inside the main form
                $("#hiddenVerificationCode").val(code);
                
                // Submit the actual form
                $("#registerForm").submit();
            });
            
            // Allow only numbers
            $("#modalCodeInput").on("input", function() {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            function startCountdown(seconds) {
                clearInterval(countdownInterval);
                $("#btnResendCode").addClass("d-none");
                $("#countdownTimer").removeClass("d-none");
                $("#modalCodeInput").val("");

                var remaining = seconds;
                updateDisplay(remaining);

                countdownInterval = setInterval(function () {
                    remaining--;
                    updateDisplay(remaining);

                    if (remaining <= 0) {
                        clearInterval(countdownInterval);
                        $("#countdownTimer").addClass("d-none");
                        $("#btnResendCode").removeClass("d-none");
                    }
                }, 1000);
            }

            function updateDisplay(sec) {
                var m = Math.floor(sec / 60);
                var s = sec % 60;
                var formatted = (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
                $("#countdownTimer").text(formatted);
            }
        });
    </script>
}
