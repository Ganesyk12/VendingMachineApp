@model LoginViewModel
@{
    ViewData["Title"] = "Login - Vending Machine";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="vending-card animate__animated animate__fadeInDown">
            <h2 class="page-title text-center mb-4"><i class="fas fa-lock me-2 text-info"></i>LOGIN</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-info small fw-bold">EMAIL ADDRESS</label>
                    <input asp-for="Email" class="form-control vending-form-control" placeholder="admin@example.com"/>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-info small fw-bold">PASSWORD</label>
                    <input asp-for="Password" class="form-control vending-form-control" type="password" placeholder="••••••••"/>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-vending w-100 mb-3">
                    <i class="fas fa-sign-in-alt me-2"></i>MASUK
                </button>

                <div class="text-center">
                    <span class="text-muted small">Belum punya akun? </span>
                    <a asp-action="Register" class="text-info small text-decoration-none fw-bold">Daftar Sekarang</a>
                </div>
            </form>
        </div>
    </div>
</div>
