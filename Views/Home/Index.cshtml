@model List<VendingMachineApp.Models.Product>
@{
    ViewData["Title"] = "Vending Machine Home";
}

<div class="container py-5">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <!-- Balance Management Section -->
        <div class="vending-card mb-4 animate__animated animate__fadeInDown">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h4 class="page-title mb-1"><i class="fas fa-wallet me-2 text-info"></i>Manajemen Saldo</h4>
                    <span class="text-muted small">Halo <b>@User.Identity.Name</b>, Anda bisa menambah saldo untuk berbelanja.</span>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-info text-info">Rp</span>
                        <input type="number" id="topupAmount" class="form-control vending-form-control" placeholder="Masukkan nominal..." min="1000" step="1000"/>
                        <button class="btn btn-info px-4 fw-bold" type="button" id="btnTopup">
                            <i class="fas fa-plus-circle me-2"></i>TAMBAH SALDO
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Header / Machine Display -->
        <div class="vending-header animate__animated animate__fadeIn">
            <div>
                <h2 class="mb-0"><i class="fas fa-robot me-2 text-info"></i>Vending Machine</h2>
                <span class="text-muted small">Silakan pilih produk favorit Anda</span>
            </div>
            <div class="money-display-group">
                <span class="money-label">Saldo Tersedia</span>
                <div class="fs-3 fw-bold text-info" id="activeBalanceDisplay">Rp @ViewBag.CurrentBalance.ToString("N0")</div>
            </div>
        </div>
        <input type="hidden" id="currentUserId" value="@ViewBag.IdUser"/>
    }
    else
    {
        <!-- Guest Welcome Card -->
        <div class="vending-card mb-4 text-center py-5 animate__animated animate__zoomIn">
            <i class="fas fa-store fa-4x text-info mb-4"></i>
            <h2 class="page-title">Selamat Datang di Vending Machine</h2>
            <p class="text-muted mb-4">Silakan masuk ke akun Anda untuk melanjutkan transaksi belanja.</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Login" class="btn-vending px-5">
                    <i class="fas fa-sign-in-alt me-2"></i>LOGIN SEKARANG
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-info rounded-pill px-5">
                    <i class="fas fa-user-plus me-2"></i>BUAT AKUN
                </a>
            </div>
        </div>
        <input type="hidden" id="currentUserId" value="0"/>
    }

    <!-- Product Table -->
    <div class="vending-table-container animate__animated animate__fadeInUp">
        <table class="table table-vending">
            <thead>
            <tr>
                <th>Nama Produk</th>
                <th>Harga</th>
                <th>Stok</th>
                <th class="text-center">Jumlah Beli</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var product in Model)
            {
                <tr class="product-row" data-id="@product.IdProduct" data-price="@product.Price" data-stock="@product.Quantity">
                    <td>
                        <span class="fw-bold">@product.Name</span>
                    </td>
                    <td>
                        <span class="text-info">Rp @product.Price.ToString("N0")</span>
                    </td>
                    <td>
                        <span class="stock-display">@product.Quantity</span>
                    </td>
                    <td>
                        <div class="qty-controls justify-content-center">
                            <button class="btn-qty btn-minus" disabled>-</button>
                            <span class="qty-display">0</span>
                            <button class="btn-qty btn-plus">+</button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Summary Bar -->
<div class="summary-bar animate__animated animate__slideInUp">
    <div class="container summary-container">
        <div class="total-info">
            <div class="d-flex gap-5">
                <div>
                    <span class="text-muted small text-uppercase d-block">Total Item</span>
                    <span id="totalQty" class="fw-bold fs-4">0</span>
                </div>
                <div>
                    <span class="text-muted small text-uppercase d-block">Total Tagihan</span>
                    <span id="totalPrice" class="total-price">Rp 0</span>
                </div>
            </div>
        </div>
        <div class="text-end">
            <div id="remainingBalanceDisplay" class="mb-2 d-none">
                <span class="text-warning small text-uppercase">Sisa Saldo Est: </span>
                <span id="remainingBalance" class="fw-bold">Rp 0</span>
            </div>
            <button id="btnCheckout" class="btn-checkout" disabled>
                BAYAR SEKARANG
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            let cart = {};
            let currentUserId = parseInt($('#currentUserId').val()) || 0;
            let currentBalance = parseCurrency($('#activeBalanceDisplay').text());

            function parseCurrency(str) {
                return parseFloat(str.replace(/[^\d]/g, '')) || 0;
            }

            // Live Format Topup Amount
            $('#topupAmount').on('input', function() {
                let val = $(this).val().replace(/[^\d]/g, '');
                if (val !== "") {
                    $(this).val(parseInt(val).toLocaleString('id-ID'));
                }
            });

            // Handle Topup
            $('#btnTopup').click(function() {
                const rawAmount = $('#topupAmount').val();
                const amount = parseCurrency(rawAmount);
                
                if (amount <= 0) { 
                    Swal.fire('Info', 'Harap masukkan nominal topup.', 'info'); 
                    return; 
                }

                $.post('/Home/AddBalance', { amount: amount }, function(response) {
                    if (response.success) {
                        currentBalance = response.newBalance;
                        $('#activeBalanceDisplay').text('Rp ' + currentBalance.toLocaleString('id-ID'));
                        $('#topupAmount').val('');
                        Swal.fire('Sukses', 'Topup Berhasil!', 'success');
                        updateUI();
                    }
                }).fail(function(xhr) {
                    Swal.fire('Error', xhr.responseText || 'Gagal melakukan topup.', 'error');
                });
            });

            // If user is logged in, init UI
            if (currentUserId > 0) {
                updateUI();
            }

            function updateUI() {
                let totalItems = 0;
                let totalPrice = 0;

                $('.product-row').each(function() {
                    let id = $(this).data('id');
                    let price = parseFloat($(this).data('price'));
                    let stock = parseInt($(this).data('stock'));
                    let currentQty = cart[id] || 0;

                    $(this).find('.qty-display').text(currentQty);
                    
                    $(this).find('.btn-minus').prop('disabled', currentQty <= 0);
                    $(this).find('.btn-plus').prop('disabled', currentQty >= stock);

                    if (currentQty > 0) {
                        totalItems += currentQty;
                        totalPrice += (currentQty * price);
                    }
                });

                $('#totalQty').text(totalItems);
                $('#totalPrice').text('Rp ' + totalPrice.toLocaleString('id-ID'));

                if (totalPrice > 0) {
                    $('#remainingBalanceDisplay').removeClass('d-none');
                    let remaining = currentBalance - totalPrice;
                    $('#remainingBalance').text('Rp ' + remaining.toLocaleString('id-ID'));
                    
                    if (remaining < 0) {
                        $('#remainingBalance').addClass('text-danger').removeClass('text-warning');
                    } else {
                        $('#remainingBalance').removeClass('text-danger').addClass('text-warning');
                    }
                } else {
                    $('#remainingBalanceDisplay').addClass('d-none');
                }

                let canCheckout = currentUserId > 0 && totalItems > 0 && currentBalance >= totalPrice;
                $('#btnCheckout').prop('disabled', !canCheckout);
            }

            $('.btn-plus').click(function() {
                if(currentUserId === 0) { 
                    Swal.fire('Info', 'Harap masuk ke akun Anda terlebih dulu.', 'info'); 
                    return; 
                }
                let row = $(this).closest('.product-row');
                let id = row.data('id');
                let stock = parseInt(row.data('stock'));
                
                if ((cart[id] || 0) < stock) {
                    cart[id] = (cart[id] || 0) + 1;
                    updateUI();
                }
            });

            $('.btn-minus').click(function() {
                let row = $(this).closest('.product-row');
                let id = row.data('id');
                
                if (cart[id] > 0) {
                    cart[id]--;
                    updateUI();
                }
            });

            $('#btnCheckout').click(function() {
                let items = [];
                for (let id in cart) {
                    if (cart[id] > 0) {
                        items.push({ productId: parseInt(id), quantity: cart[id] });
                    }
                }

                const data = {
                    idUser: currentUserId,
                    items: items
                };

                $.ajax({
                    url: '/Home/ProcessCheckout',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function(response) {
                        if (response.success) {
                            currentBalance = response.newBalance;
                            $('#activeBalanceDisplay').text('Rp ' + currentBalance.toLocaleString('id-ID'));
                            
                            Swal.fire({
                                icon: 'success',
                                title: 'Transaksi Berhasil!',
                                html: 'Sisa saldo Anda: <b>Rp ' + currentBalance.toLocaleString('id-ID') + '</b>',
                                confirmButtonText: 'OKE',
                                confirmButtonColor: '#0dcaf0'
                            }).then(() => {
                                // Reset cart and reload product list (for stock updates)
                                cart = {};
                                location.reload(); 
                            });
                        }
                    },
                    error: function(xhr) {
                        Swal.fire('Gagal', xhr.responseText || 'Terjadi kesalahan sistem.', 'error');
                    }
                });
            });
        });
    </script>
}
