@model IEnumerable<VendingMachineApp.Models.BalanceHistory>
@{
    ViewData["Title"] = "History Saldo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">History Saldo Saya</h1>
    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-info rounded-pill px-4">
        <i class="fas fa-arrow-left me-2"></i>Halaman Utama
    </a>
</div>

<div class="vending-table-container animate__animated animate__fadeIn">
    <div class="table-responsive">
        <table class="table table-vending">
            <thead>
            <tr>
                <th>Tanggal</th>
                <th>Keterangan</th>
                <th>Masuk (Debit)</th>
                <th>Keluar (Credit)</th>
                <th>Status</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var history in Model)
            {
                <tr>
                    <td>
                        <span class="small text-muted">@history.DateCreated.ToString("g")</span>
                    </td>
                    <td>
                        <span class="fw-bold">@history.Description</span>
                        <br/>
                        <small class="text-muted">Type: @history.TransactionType</small>
                    </td>
                    <td>
                        @if (history.DebitBalance > 0)
                        {
                            <span class="text-success fw-bold">+ Rp @history.DebitBalance.ToString("N0")</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        @if (history.CreditBalance > 0)
                        {
                            <span class="text-danger fw-bold">- Rp @history.CreditBalance.ToString("N0")</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(history.Status == "A" ? "bg-success" : "bg-warning")">
                            @(history.Status == "A" ? "Berhasil" : "Pending")
                        </span>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <i class="fas fa-history fa-3x text-muted mb-3 d-block"></i>
                        <p class="text-muted">Belum ada riwayat transaksi saldo.</p>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
